generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum MenuType {
  BREAKFAST
  RESTAURANT
  POOL_BAR
  BEACH_BAR
  ROOM_SERVICE
  SPA
  ACTIVITIES
  OTHER
}

enum WaiterCallStatus {
  PENDING
  ACKNOWLEDGED
  COMPLETED
  CANCELED
}

enum WaiterCallType {
  WAITER
  BILL
  ORDER
}

enum PassStation {
  KITCHEN
  BAR
  COLD
  DESSERT
}

enum PassSignalStatus {
  READY
  PICKED_UP
  DELIVERED
}

enum SubscriptionPlan {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum ItemLabel {
  OFFER
  BEST
  NEW
}

enum VenueSpotType {
  TABLE
  ROOM
  SUNBED
}

enum CuisineType {
  MEDITERRANEAN
  GREEK
  ITALIAN
  GOURMET
  SEAFOOD
  GRILL
  CAFE_BAR
  ASIAN
  INTERNATIONAL
  VEGETARIAN
  OTHER
}

enum SupportedLanguage {
  GR
  EN
  DE
  FR
}

enum OrganizationActivity {
  RESTAURANT
  HOTEL
  CAFE_BAR
  BEACH_BAR
  OTHER
}

enum DiagnosticSeverity {
  INFO
  WARN
  ERROR
}

enum DiagnosticStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  phone     String?
  mobile    String?
  vatNumber String?
  activity  OrganizationActivity?
  city      String?
  notes     String?
  geminiTokenLimitOverride Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  venues       Venue[]
  subscription Subscription?
  pushSubscriptions PushSubscription[]
  diagnosticReports ClientDiagnosticReport[]
  geminiUsageEvents GeminiUsageEvent[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(STAFF)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pushSubscriptions PushSubscription[]
  diagnosticReports ClientDiagnosticReport[]

  @@index([organizationId])
}

model PushSubscription {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String
  venueId        String?
  staffMemberId  String?
  endpoint       String   @unique
  p256dh         String
  auth           String
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  venue       Venue?            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  staffMember VenueStaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([venueId])
  @@index([staffMemberId])
}

model Subscription {
  id               String             @id @default(cuid())
  organizationId   String             @unique
  plan             SubscriptionPlan   @default(TRIAL)
  status           SubscriptionStatus @default(TRIALING)
  stripeCustomerId String?
  stripeSubId      String?
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  trialMidEmailSentAt     DateTime?
  trialEndingEmailSentAt  DateTime?
  trialGraceStartedEmailSentAt DateTime?
  trialExpiredEmailSentAt DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Venue {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String   @unique
  staffToken          String   @unique @default(cuid())
  kitchenScreenToken  String   @unique @default(cuid())
  barScreenToken      String   @unique @default(cuid())
  coldScreenToken     String   @unique @default(cuid())
  dessertScreenToken  String   @unique @default(cuid())
  description    String?
  cuisineType    CuisineType?
  logoUrl        String?
  primaryColor   String   @default("#2563EB")
  secondaryColor String   @default("#06B6D4")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  menus             Menu[]
  waiterCalls       WaiterCall[]
  passSignals       PassSignal[]
  spots             VenueSpot[]
  staffMembers      VenueStaffMember[]
  stationScreens    VenueStationScreen[]
  settings          VenueSetting?
  pushSubscriptions PushSubscription[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model VenueSetting {
  id               String   @id @default(cuid())
  venueId          String   @unique
  brandName        String?
  openingHours     Json?
  operationsConfig Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model VenueSpot {
  id        String        @id @default(cuid())
  venueId   String
  type      VenueSpotType
  label     String
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, type, label])
  @@index([venueId, sortOrder])
}

model VenueStaffMember {
  id          String   @id @default(cuid())
  venueId     String
  name        String   @db.VarChar(60)
  roleLabel   String   @db.VarChar(40)
  zoneId        String?  @db.VarChar(60)
  messageScope  String?  @db.VarChar(40)
  stations      String[]
  memberToken String   @unique
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue             Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  pushSubscriptions PushSubscription[]
  deliveredPassSignals PassSignal[]

  @@index([venueId, sortOrder])
}

model Menu {
  id        String   @id @default(cuid())
  venueId   String
  name      String
  type      MenuType @default(RESTAURANT)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue      Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  categories Category[]

  @@index([venueId])
}

model Category {
  id        String   @id @default(cuid())
  menuId    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu         Menu                  @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items        Item[]
  translations CategoryTranslation[]

  @@index([menuId])
}

model CategoryTranslation {
  id         String            @id @default(cuid())
  categoryId String
  language   SupportedLanguage
  name       String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, language])
}

model Item {
  id         String     @id @default(cuid())
  categoryId String
  price      Decimal    @db.Decimal(10, 2)
  photoUrl   String?
  label      ItemLabel?
  available  Boolean    @default(true)
  extras     Json?
  sortOrder  Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  category     Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations ItemTranslation[]
  photos       Photo[]

  @@index([categoryId])
}

model ItemTranslation {
  id          String            @id @default(cuid())
  itemId      String
  language    SupportedLanguage
  name        String
  description String?
  ingredients String?
  allergens   String?

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, language])
}

model Photo {
  id            String   @id @default(cuid())
  itemId        String
  url           String
  optimizedUrl  String?
  createdAt     DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model WaiterCall {
  id          String           @id @default(cuid())
  venueId     String
  type         WaiterCallType   @default(WAITER)
  tableNumber  String?
  roomNumber   String?
  sunbedNumber String?
  status       WaiterCallStatus @default(PENDING)
  orderItems  Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, status])
}

model PassSignal {
  id               String           @id @default(cuid())
  venueId          String
  station          PassStation
  stationScreenId  String?
  tableNumber      String?
  roomNumber       String?
  sunbedNumber     String?
  message          String?          @db.VarChar(80)
  status           PassSignalStatus @default(READY)
  readyAt          DateTime         @default(now())
  pickedUpAt       DateTime?
  deliveredAt      DateTime?
  deliveredByStaffMemberId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  venue                   Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  stationScreen           VenueStationScreen? @relation(fields: [stationScreenId], references: [id], onDelete: SetNull)
  deliveredByStaffMember  VenueStaffMember?   @relation(fields: [deliveredByStaffMemberId], references: [id], onDelete: SetNull)

  @@index([venueId, status])
  @@index([deliveredByStaffMemberId])
}

model VenueStationScreen {
  id          String      @id @default(cuid())
  venueId     String
  station     PassStation
  label       String      @db.VarChar(40)
  spotPrefix  String?     @db.VarChar(20)
  quickChips  String[]    @default([])
  screenToken String      @unique @default(cuid())
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  venue       Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  passSignals PassSignal[]

  @@index([venueId, station, sortOrder])
}

model RegistrationOtp {
  id         String   @id @default(cuid())
  email      String   @unique
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  lastSentAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(1)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model SupervisorOperator {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PlanCatalog {
  plan               SubscriptionPlan @id
  sortOrder          Int              @default(0)
  name               String
  priceMonthly       Decimal          @db.Decimal(10, 2)
  priceDisplay       String?
  periodLabel        String           @default("/μήνα")
  description        String?
  features           Json             @default("[]")
  maxVenues          Int
  maxMenusPerVenue   Int?
  maxItems           Int?
  maxGeminiTokensPerMonth Int?
  ctaLabel           String?
  badge              String?
  highlighted        Boolean          @default(false)
  visibleOnPricing   Boolean          @default(true)
  trialDays          Int?
  updatedAt          DateTime         @updatedAt
}

model GeminiUsageEvent {
  id             String   @id @default(cuid())
  organizationId String
  operation      String
  model          String
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  totalTokens    Int      @default(0)
  success        Boolean
  httpStatus     Int?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model StripeWebhookEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model ClientDiagnosticReport {
  id              String             @id @default(cuid())
  organizationId  String?
  userId          String?
  userEmail       String?
  severity        DiagnosticSeverity @default(ERROR)
  status          DiagnosticStatus   @default(OPEN)
  source          String
  category        String
  message         String
  errorCode       String?
  stack           String?            @db.Text
  context         Json?
  fingerprint     String
  occurrenceCount Int                @default(1)
  firstSeenAt     DateTime           @default(now())
  lastSeenAt      DateTime           @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?
  internalNote    String?            @db.Text

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, lastSeenAt])
  @@index([status, lastSeenAt])
  @@index([fingerprint, status])
}
