# =============================================================================
# MenuOS — όλες οι ρυθμίσεις (αντιγραφή σε .env και συμπλήρωση τιμών)
# Το docker-compose.prod.yml και η εφαρμογή διαβάζουν από αυτό το αρχείο.
# =============================================================================

# --- App / URLs ---
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-min-32-chars
NODE_ENV=development
PORT=3000

# --- Database (Postgres) ---
POSTGRES_USER=menuos
POSTGRES_PASSWORD=menuos
POSTGRES_DB=menuos
# Hostname μέσα στο Docker network (prod: menuos-db — όχι "postgres", συγκρούεται με MatchWork)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_URL=postgresql://menuos:menuos@localhost:5433/menuos

# --- Email (Office 365 — ίδιο mailbox με MatchWork) ---
MAILBOX_USER=admin@s1cloud.b-os.gr
MAILBOX_PASSWORD=
SMTP_FROM="MenuOS <admin@s1cloud.b-os.gr>"
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Admin notifications (νέες εγγραφές & πληρωμές, comma-separated) ---
MENUOS_NOTIFY_EMAIL=info@b-os.gr

# --- Web Push (ειδοποιήσεις σερβιτόρου στο κινητό) ---
# Δημιούργησε κλειδιά: node scripts/generate-vapid-keys.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@b-os.gr

# --- Stripe (MenuOS only — see docs/STRIPE-MENUOS.md) ---
MENUOS_STRIPE_SECRET_KEY=
MENUOS_STRIPE_WEBHOOK_SECRET=
BILLING_MOCK=false

# --- SEO / Search ---
GOOGLE_SITE_VERIFICATION=
INDEXNOW_HOST=menuos.gr
INDEXNOW_KEY=

# --- Cloudflare R2 (optional — without R2, photos save on server disk) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=menuos
R2_PUBLIC_URL=
# Local photo storage when R2 is not set (production Docker: /app/data/uploads)
PHOTO_UPLOAD_DIR=

# --- Deploy / server scripts (production) ---
RUN_DB_PUSH=1
RUN_INDEXNOW=0
STRICT=0
# Secret for cron APIs: trial-reminders, demo-cleanup, pass-signal-cleanup
CRON_SECRET=
# Pause demo-taverna waiter-call cleanup until this ISO date (showcase / demos)
# DEMO_SHOWCASE_UNTIL=2026-07-15T23:59:59.000Z

# --- Supervisor ops panel (/supervisor) ---
# Production: create operators via supervisor panel / DB (scripts/migrations/013).
# Dev-only fallback login (disabled when NODE_ENV=production):
SUPERVISOR_USERNAME=
SUPERVISOR_PASSWORD=
# Optional; falls back to NEXTAUTH_SECRET
SUPERVISOR_SESSION_SECRET=
# Comma-separated usernames hidden from /supervisor/users (SUPERVISOR_USERNAME is always hidden)
SUPERVISOR_HIDDEN_USERNAMES=

# --- Menu auto-translation (categories & items: GR → EN/DE/FR) ---
# Optional DeepL key (recommended). Without it, MyMemory free API is used as fallback.
DEEPL_API_KEY=
# DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# --- PDF import OCR (scan/image pages — free tier at ocr.space) ---
# Register: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=
# OCR_SPACE_ENGINE=2
# OCR_SPACE_LANGUAGE=gre

# --- Demo seed (scripts/seed-master-user.mjs) ---
SEED_MASTER_EMAIL=mosxakisn@gmail.com
SEED_MASTER_PASSWORD=
SEED_MASTER_NAME="MenuOS Master"
SEED_BUSINESS_NAME="MenuOS Demo"
