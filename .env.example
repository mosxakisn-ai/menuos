# App
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-min-32-chars

# Database
DATABASE_URL=postgresql://menuos:menuos@localhost:5432/menuos

# Google Search Console (optional)
GOOGLE_SITE_VERIFICATION=

# Cloudflare R2 (Phase 1b — photo uploads)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=menuos
# R2_PUBLIC_URL=

# Email — ίδιο mailbox με MatchWork (BM Cloud Admin / admin@s1cloud.b-os.gr)
# Copy MAILBOX_PASSWORD from BM admin server — do not commit the real password.
MAILBOX_PASSWORD=
MAILBOX_USER=admin@s1cloud.b-os.gr
SMTP_FROM="MenuOS <admin@s1cloud.b-os.gr>"
# Optional overrides (defaults: smtp.office365.com:587)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# Admin notifications — νέες εγγραφές & πληρωμές (comma-separated)
MENUOS_NOTIFY_EMAIL=info@b-os.gr

# IndexNow (deploy)
# INDEXNOW_HOST=menuos.gr
# INDEXNOW_KEY=

# Stripe (MenuOS-only — NOT MatchWork — see docs/STRIPE-MENUOS.md)
# Setup: MENUOS_STRIPE_SECRET_KEY=sk_live_... node scripts/setup-menuos-stripe.mjs
MENUOS_STRIPE_SECRET_KEY=
MENUOS_STRIPE_WEBHOOK_SECRET=

# Dev: activate plans without Stripe
# BILLING_MOCK=true
